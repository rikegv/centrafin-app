rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar: verifica se o perfil do usuário é admin
    function isAdmin() {
      let perfil = get(/databases/$(database)/documents/Usuarios/$(request.auth.token.email)).data.perfil;
      return perfil == "master" || perfil == "super_admin";
    }

    // Função auxiliar: verifica se o usuário tem permissão para um menu específico ou se é admin
    function hasMenu(menuName) {
      let userData = get(/databases/$(database)/documents/Usuarios/$(request.auth.token.email)).data;
      return userData.perfil == "master" || userData.perfil == "super_admin" ||
             (userData.menus_permitidos != null && menuName in userData.menus_permitidos);
    }

    // Perfil CONSULTA (Read-Only) — auditoria 2026-05-26.
    // Defesa em profundidade: bloqueia qualquer escrita vinda do front-end de
    // um usuário com perfil "consulta", mesmo que ele tenha menus operacionais
    // marcados. Leitura segue normal (KPIs, gráficos, busca, exportação).
    // Implementação: lookup em /Usuarios/{email}.perfil — alinhado com o
    // padrão existente de isAdmin/hasMenu (NÃO usa custom claim).
    function isConsulta() {
      let perfil = get(/databases/$(database)/documents/Usuarios/$(request.auth.token.email)).data.perfil;
      return perfil == "consulta";
    }

    // Função auxiliar: verifica se o perfil é super_admin
    function isSuperAdmin() {
      let perfil = get(/databases/$(database)/documents/Usuarios/$(request.auth.token.email)).data.perfil;
      return perfil == "super_admin";
    }

    // Função auxiliar: verifica se o perfil é master
    function isMaster() {
      let perfil = get(/databases/$(database)/documents/Usuarios/$(request.auth.token.email)).data.perfil;
      return perfil == "master";
    }

    // LANCAMENTOS — base do Faturamento/CRF.
    // Auditoria 2026-05-13 (Privilege Segregation): leitura restrita aos menus
    // que efetivamente leem a coleção (CRF operacional, Dashboard Master,
    // Aging standalone). Antes era aberta a qualquer autenticado.
    // Escrita continua exclusiva do admin (mutações via CRF operacional).
    match /Lancamentos/{docId} {
      allow read: if request.auth != null && (
        isAdmin()
        || hasMenu('contas_receber')      // CRF operacional (Nível 1)
        || hasMenu('dashboard_master')    // Dashboard Geral (Nível 1)
        || hasMenu('dash_aging')          // Aging standalone (Nível 2)
      );
      allow write: if request.auth != null && isAdmin() && !isConsulta();
    }

    // METAS FINANCEIRAS
    match /MetasFinanceiras/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin() && !isConsulta();
    }

    // USUARIOS
    // Auditoria 2026-05-14 (Monitor de Acessos): além do admin (que mantém
    // CRUD completo), o próprio usuário pode atualizar APENAS os campos de
    // presença (is_online + ultimo_acesso) no SEU próprio doc — necessário
    // para o motor de presence em login.html + sidebar.js. Auto-elevação de
    // perfil/permissões fica bloqueada pelo `affectedKeys().hasOnly(...)`.
    match /Usuarios/{docId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && isAdmin() && !isConsulta();
      // Auditoria 2026-05-26 (Perfil Consulta): bloqueio explícito do perfil
      // consulta nas rotas de admin (defesa em profundidade). A self-update de
      // presença (is_online/ultimo_acesso) segue liberada para QUALQUER perfil
      // — necessária para o motor de presence em login.html + sidebar.js,
      // inclusive do usuário consulta (aparece online na tela de Monitor).
      allow update: if request.auth != null && (
        (isAdmin() && !isConsulta())
        || (
          request.auth.token.email == docId
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['is_online', 'ultimo_acesso'])
        )
      );
    }

    // HISTÓRICO DE ACESSOS — auditoria 2026-05-14 (Monitor de Acessos).
    // Qualquer autenticado pode REGISTRAR um login, MAS apenas para o próprio
    // e-mail (defesa em profundidade — impede um user criar fake LOGIN pra
    // outro). Leitura é restrita aos perfis admin (master / super_admin) —
    // a UI vive em master.html. Updates e deletes são bloqueados — logs
    // não podem ser apagados/falsificados pós-criação.
    match /HistoricoAcessos/{docId} {
      allow create: if request.auth != null
                     && request.resource.data.email == request.auth.token.email;
      allow read: if request.auth != null && isAdmin();
      allow update, delete: if false;
    }

    // LOGS
    match /Logs/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // BASES DE REFERÊNCIA — cadastros compartilhados (empresas, fornecedores, clientes, categorias)
    // Leitura: qualquer autenticado (usado para preencher dropdowns).
    // Escrita: apenas admin (CRUD vive em Gestão de Parceiros / master).
    match /Base_Empresas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin() && !isConsulta();
    }
    match /Base_Fornecedores/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin() && !isConsulta();
    }
    match /Base_Clientes/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin() && !isConsulta();
    }
    match /Base_Categorias/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin() && !isConsulta();
    }
    match /Base_Areas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin() && !isConsulta();
    }
    match /Base_Responsaveis/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin() && !isConsulta();
    }
    // Base alimentada automaticamente pelo ETL de Custo de Folha — por isso a
    // escrita é liberada para usuários com o menu custo_folha (além de admin).
    match /Base_Centros_Custo/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isAdmin() || hasMenu('custo_folha')) && !isConsulta();
    }

    // CUSTOS FOLHA — Drop & Replace por competência.
    // Auditoria 2026-05-13 (Privilege Segregation): leitura aberta para quem
    // tem o Gerenciador (Nível 1) OU o card do Dashboard (Nível 2). Escrita
    // continua exclusiva do Gerenciador (Nível 1) — Nível 2 é read-only.
    match /CustosFolha/{docId} {
      allow read: if request.auth != null && (
        isAdmin()
        || hasMenu('custo_folha')         // Gerenciador Folha (Nível 1)
        || hasMenu('dash_custo_folha')    // Card no Dashboard / standalone (Nível 2)
      );
      allow write: if request.auth != null && (isAdmin() || hasMenu('custo_folha')) && !isConsulta();
    }

    // CONTAS A PAGAR — Fase 1 + Fase 2 (auditoria 2026-04-29).
    // Coleção foi renomeada para ContasAPagar (com "A" separado) seguindo a
    // especificação da Fase 2 do ETL. Quem tem o menu contas_pagar pode ler
    // e gravar; o parser TXT também grava nesta coleção.
    // Auditoria 2026-05-14: o módulo novo "Gerenciador Contas a Pagar" também
    // grava aqui (mesma collection física), então aceitamos ambas as chaves.
    match /ContasAPagar/{docId} {
      // Auditoria 2026-05-18: leitura também liberada para o módulo Custo de
      // Folha (Gerenciador + Dashboard) — integração PJ → Folha lê os
      // lançamentos com tipo_entidade == "Fornecedor Interno - PJ" para
      // compor o Custo Total. Escrita continua exclusiva do Contas a Pagar.
      allow read: if request.auth != null && (
        hasMenu('contas_pagar')
        || hasMenu('gerenciador_contas_pagar')
        || hasMenu('custo_folha')
        || hasMenu('dash_custo_folha')
      );
      allow write: if request.auth != null && (
        hasMenu('contas_pagar') || hasMenu('gerenciador_contas_pagar')
      ) && !isConsulta();
    }

    // REGRAS DE CONCILIAÇÃO — dicionário "De-Para" para o ETL automático.
    // Leitura: qualquer autenticado (o ETL roda com a sessão do usuário que
    // disparou a importação). Escrita: apenas admin/super_admin (o CRUD
    // vive na aba Configurações > Regras de Classificação).
    match /RegrasConciliacao/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin() && !isConsulta();
    }

    // ÁREAS CONTAS A PAGAR — Fase 2.1 (auditoria 2026-04-29).
    // Coleção independente de Base_Centros_Custo (usada no Custo de Folha).
    // Aqui ficam as "áreas" exclusivas do módulo Contas a Pagar — alimentam
    // tanto o dropdown das RegrasConciliacao quanto o datalist do wizard.
    // Leitura aberta para autenticados; escrita restrita ao admin (CRUD em
    // master.html → Configurações → Regras de Classificação → Áreas).
    match /AreasContasPagar/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin() && !isConsulta();
    }

    // CP_GESTORES — Frente 3 (auditoria 2026-05-20).
    // Cadastro de gestores responsáveis pelos Centros de Custo. Base para
    // futuras auditorias de estouro de orçamento e fluxos de notificação.
    // Leitura aberta para autenticados (preenche dropdowns na área de
    // Cadastro de Áreas). Escrita restrita ao admin (CRUD em master.html →
    // Regras de Classificação → Áreas & Gestores).
    match /CP_Gestores/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin() && !isConsulta();
    }

    // CP_BASE_MESTRA — auditoria 2026-05-14 (Fase 1 ETL Preditivo do Contas a Pagar).
    // Banco "aprendizado" do motor de quarentena: cada doc mapeia uma
    // combinação (fornecedor + despesa) → classificação + centro_custo +
    // periodicidade. O ETL lê para autoclassificar e escreve quando o usuário
    // confirma uma nova regra no modal-cp-quarentena. Mesma permissão da
    // ContasAPagar: tanto a tela legada (contas_pagar) quanto o novo
    // "Gerenciador Contas a Pagar" leem e gravam aqui.
    match /CP_BaseMestra/{docId} {
      allow read: if request.auth != null && (
        hasMenu('contas_pagar') || hasMenu('gerenciador_contas_pagar')
      );
      allow write: if request.auth != null && (
        hasMenu('contas_pagar') || hasMenu('gerenciador_contas_pagar')
      ) && !isConsulta();
    }

    // FORNECEDORES — auditoria 2026-05-15 (pivot Excel nativo) +
    // 2026-05-18 Fase 3 (Esteira de Aprovação). Banco relacional do Contas a
    // Pagar. PK = Cód. do Fornecedor (docId = String(codigo)). Leitura:
    // qualquer autenticado (precisa servir lookups em outras telas, incl.
    // o cross-reference de CC do Custo de Folha).
    // Escrita: APENAS isAdmin() (master/super_admin). Demais perfis com o
    // menu gerenciador_contas_pagar passam pela esteira em
    // /CP_SolicitacoesAprovacao — defesa em profundidade (UI + DB).
    match /Fornecedores/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin() && !isConsulta();
    }

    // CP_SOLICITACOESAPROVACAO — auditoria 2026-05-18 (Fase 3 — Governança).
    // Refatoração 2026-05-18 (B): separação operacional × governança.
    // Refatoração 2026-07-03: Sistema de Aprovações v2 (Dois Níveis).
    //   - create: expandido para aceitar master de QUALQUER módulo (CRF, CP,
    //     Folha, Metas) via isMaster(), além de hasMenu('aprovacoes') e
    //     hasMenu('gerenciador_contas_pagar'). Master pode criar solicitação,
    //     mas NÃO pode aprovar/rejeitar.
    //   - update/delete: restrito a isSuperAdmin() — master NÃO pode
    //     auto-aprovar. Audit trail imutável.
    match /CP_SolicitacoesAprovacao/{docId} {
      allow read: if request.auth != null && (
        isAdmin() || hasMenu('aprovacoes') || hasMenu('gerenciador_contas_pagar')
      );
      // Sistema de Aprovações v2 (2026-07-03): create expandido para aceitar
      // master de QUALQUER módulo (CRF, CP, Folha, Metas) — não apenas
      // gerenciador_contas_pagar. Master pode criar solicitação, mas NÃO pode
      // aprovar/rejeitar (update restrito a isSuperAdmin).
      allow create: if request.auth != null
        && (hasMenu('aprovacoes') || hasMenu('gerenciador_contas_pagar') || isMaster())
        && request.resource.data.solicitado_por_email == request.auth.token.email
        && request.resource.data.status == 'Pendente'
        && !isConsulta();
      // Aprovar/Rejeitar: SOMENTE super_admin — master NÃO pode auto-aprovar.
      allow update: if request.auth != null && isSuperAdmin() && !isConsulta();
      // Audit trail imutável — delete restrito a super_admin.
      allow delete: if request.auth != null && isSuperAdmin() && !isConsulta();
    }

    // CP_BASE_DESPESAS — auditoria 2026-05-15 (refatoração ETL).
    // Dicionário "Despesa → Per.Evento + Per.Valor". PK = slug da despesa
    // normalizada (NFD, sem pontuação, UPPERCASE). Alimentado pela importação
    // .xlsx/.csv da Central de Importações + pelo modal de Quarentena do TXT.
    // O motor ETL roda fuzzy match (Levenshtein >= 0.80 + prefix) contra a
    // memória dessa coleção pra reconciliar despesas truncadas pelo ERP.
    // Mesma permissão da ContasAPagar.
    match /CP_Base_Despesas/{docId} {
      allow read: if request.auth != null && (
        isAdmin() || hasMenu('gerenciador_contas_pagar')
      );
      allow write: if request.auth != null && (
        isAdmin() || hasMenu('gerenciador_contas_pagar')
      ) && !isConsulta();
    }

    // CP_BENEFICIOS_PJ — Frente 2/3 (auditoria 2026-05-21).
    // Custos mensais de benefícios (VR/VT/Total) por PJ. Cruzados via
    // Fornecedores.codigo_beneficio_folha (cadastro prévio). Lidos pelo
    // Dashboard de Folha (compõe o custo unificado fatura+benefícios) e
    // gravados pelo importador da Central no Gerenciador Contas a Pagar.
    // Leitura aberta pra quem tem custo_folha (operacional + dashboard) ou
    // gerenciador_contas_pagar; escrita exclusiva pro gerenciador (admin
    // herda via isAdmin no `hasMenu`).
    match /CP_Beneficios_PJ/{docId} {
      allow read: if request.auth != null && (
        isAdmin()
        || hasMenu('custo_folha')
        || hasMenu('dash_custo_folha')
        || hasMenu('gerenciador_contas_pagar')
      );
      allow write: if request.auth != null && (
        isAdmin() || hasMenu('gerenciador_contas_pagar')
      ) && !isConsulta();
    }

    // METADADOS — telemetria leve de eventos do sistema (auditoria 2026-05-18).
    // Doc fixo "UltimaImportacao_CP" registra timestamp + tipo + quantidade
    // da última importação ETL do Gerenciador Contas a Pagar. Leitura aberta
    // (header mostra "Última base importada em..."); escrita restrita aos
    // perfis que de fato disparam o ETL (admin + gerenciador_contas_pagar).
    match /Metadados/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        isAdmin() || hasMenu('gerenciador_contas_pagar')
      ) && !isConsulta();
    }
  }
}
