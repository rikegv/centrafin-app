rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar: verifica se o perfil do usuário é admin
    function isAdmin() {
      let perfil = get(/databases/$(database)/documents/Usuarios/$(request.auth.token.email)).data.perfil;
      return perfil == "master" || perfil == "super_admin";
    }

    // Função auxiliar: verifica se o usuário tem permissão para um menu específico ou se é admin
    function hasMenu(menuName) {
      let userData = get(/databases/$(database)/documents/Usuarios/$(request.auth.token.email)).data;
      return userData.perfil == "master" || userData.perfil == "super_admin" ||
             (userData.menus_permitidos != null && menuName in userData.menus_permitidos);
    }

    // LANCAMENTOS
    match /Lancamentos/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // METAS FINANCEIRAS
    match /MetasFinanceiras/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // USUARIOS
    match /Usuarios/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // LOGS
    match /Logs/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // BASES DE REFERÊNCIA — cadastros compartilhados (empresas, fornecedores, clientes, categorias)
    // Leitura: qualquer autenticado (usado para preencher dropdowns).
    // Escrita: apenas admin (CRUD vive em Gestão de Parceiros / master).
    match /Base_Empresas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /Base_Fornecedores/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /Base_Clientes/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /Base_Categorias/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /Base_Areas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /Base_Responsaveis/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    // Base alimentada automaticamente pelo ETL de Custo de Folha — por isso a
    // escrita é liberada para usuários com o menu custo_folha (além de admin).
    match /Base_Centros_Custo/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isAdmin() || hasMenu('custo_folha'));
    }

    // CUSTOS FOLHA — Leitura e Escrita protegidas pelo controle de acesso (Drop & Replace)
    match /CustosFolha/{docId} {
      allow read, write: if request.auth != null && hasMenu('custo_folha');
    }

    // CONTAS A PAGAR — Fase 1 + Fase 2 (auditoria 2026-04-29).
    // Coleção foi renomeada para ContasAPagar (com "A" separado) seguindo a
    // especificação da Fase 2 do ETL. Quem tem o menu contas_pagar pode ler
    // e gravar; o parser TXT também grava nesta coleção.
    match /ContasAPagar/{docId} {
      allow read, write: if request.auth != null && hasMenu('contas_pagar');
    }

    // REGRAS DE CONCILIAÇÃO — dicionário "De-Para" para o ETL automático.
    // Leitura: qualquer autenticado (o ETL roda com a sessão do usuário que
    // disparou a importação). Escrita: apenas admin/super_admin (o CRUD
    // vive na aba Configurações > Regras de Classificação).
    match /RegrasConciliacao/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ÁREAS CONTAS A PAGAR — Fase 2.1 (auditoria 2026-04-29).
    // Coleção independente de Base_Centros_Custo (usada no Custo de Folha).
    // Aqui ficam as "áreas" exclusivas do módulo Contas a Pagar — alimentam
    // tanto o dropdown das RegrasConciliacao quanto o datalist do wizard.
    // Leitura aberta para autenticados; escrita restrita ao admin (CRUD em
    // master.html → Configurações → Regras de Classificação → Áreas).
    match /AreasContasPagar/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
  }
}
