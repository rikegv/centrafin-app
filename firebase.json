{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "**/.*",
      "**/node_modules/**",
      "populador.html",
      "**/*.mjs",
      "**/*.ps1",
      "**/*.py",
      "**/tmp_*.js",
      "**/clean_*.js",
      "**/*.cjs",
      "adc_tmp.json",
      "**/*.md",
      "package.json",
      "package-lock.json",
      "centrafin-app.code-workspace"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=0, no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}
